{
  "name": "@obtrace/browser",
  "version": "2.7.0",
  "description": "Obtrace Browser SDK with frontend wrappers",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/types/auto.d.ts",
      "import": "./dist/auto.js"
    },
    "./react": {
      "types": "./dist/types/wrappers/frontend/react.d.ts",
      "import": "./dist/wrappers/frontend/react.js"
    },
    "./sourcemaps": {
      "types": "./dist/types/sourcemaps.d.ts",
      "import": "./dist/sourcemaps.js"
    },
    "./browser": {
      "types": "./dist/types/browser_entry.d.ts",
      "import": "./dist/browser_entry.js"
    }
  },
  "typesVersions": {
    "*": {
      "auto": [
        "./dist/types/auto.d.ts"
      ],
      "react": [
        "./dist/types/wrappers/frontend/react.d.ts"
      ],
      "sourcemaps": [
        "./dist/types/sourcemaps.d.ts"
      ],
      "browser": [
        "./dist/types/browser_entry.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node esbuild.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.6.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^1.30.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/instrumentation-document-load": "^0.43.0",
    "@opentelemetry/instrumentation-fetch": "^0.57.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.58.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-trace-web": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@rrweb/types": "^2.0.0-alpha.17",
    "rrweb": "^2.0.0-alpha.17"
  }
}
