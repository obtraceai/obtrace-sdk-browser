{
  "name": "@obtrace/sdk-browser",
  "version": "1.1.0",
  "description": "Obtrace Browser SDK with frontend wrappers",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/types/auto.d.ts",
      "import": "./dist/auto.js"
    },
    "./react": {
      "types": "./dist/types/wrappers/frontend/react.d.ts",
      "import": "./dist/wrappers/frontend/react.js"
    },
    "./browser": {
      "types": "./dist/types/browser_entry.d.ts",
      "import": "./dist/browser_entry.js"
    }
  },
  "typesVersions": {
    "*": {
      "auto": [
        "./dist/types/auto.d.ts"
      ],
      "react": [
        "./dist/types/wrappers/frontend/react.d.ts"
      ],
      "browser": [
        "./dist/types/browser_entry.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node esbuild.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@rrweb/types": "^2.0.0-alpha.17",
    "rrweb": "^2.0.0-alpha.17"
  }
}
